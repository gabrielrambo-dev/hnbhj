{
  "name": "nemotron-desktop",
  "productName": "Nemotron",
  "version": "1.1.3",
  "description": "Nemotron - assistente de IA desktop com projetos, artifacts, terminal e agente de código usando NVIDIA API.",
  "author": "Cythar Dev",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --win nsis --x64 --publish=never",
    "dist:portable": "npm run build && electron-builder --win portable --x64 --publish=never",
    "pack": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "lucide-react": "0.544.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "@types/node": "24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "9.2.1",
    "cross-env": "10.0.0",
    "electron": "42.5.0",
    "electron-builder": "26.15.3",
    "typescript": "5.9.2",
    "vite": "8.1.0",
    "wait-on": "9.0.1"
  },
  "build": {
    "appId": "dev.cythar.nemotron",
    "productName": "Nemotron",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/assets/nemotron.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nemotron",
      "artifactName": "Nemotron-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Nemotron-Portable-${version}.${ext}"
    }
  }
}
